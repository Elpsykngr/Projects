#include <iostream>
#include <string>
#include <cmath>
#include <random>
using namespace std;

int main() {
	random_device seed;
	mt19937 engine(seed());
	uniform_int_distribution<int> range(0,255);

	int r = 0, g = 0, b = 0;
	double brightness;

	string code, exit;
	string text = "What kind of a color is this!";
	while (true) {
		getline(cin, exit);
		if (exit == "stop") {
			break;
		}

		unsigned int red = range(engine);
		unsigned int green = range(engine);
		unsigned int blue = range(engine);

		r += red;
		g += green;
		b += blue;

		brightness = round(((red + green + blue) / 3.0 / 255.0) * 100);

		cout << "\033[38;2;" << red << ";" << green << ";" << blue << "m" << text << "\033[0m" << endl;
		code = "\\033[38;2;" + to_string(red) + ";" + to_string(green) + ";" + to_string(blue) + "m\\033[0m";
		cout << code << endl;
		cout << "Red: " << r << endl;
		cout << "Green: " << g << endl;
		cout << "Blue: " << b << endl;
		cout << "Brightness: " << brightness << "%" << endl;
	} return 0;
}
